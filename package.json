{
  "name": "@hoshock/orbit",
  "version": "0.2.0",
  "private": true,
  "description": "Terminal-based code review tool with AI prompt export",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "orbit": "./bin/orbit"
  },
  "files": [
    "src",
    "bin",
    "assets",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "cli",
    "code-review",
    "diff",
    "terminal",
    "tui",
    "git"
  ],
  "author": "Tsuyoshi ISHIDA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hoshock/orbit.git"
  },
  "bugs": {
    "url": "https://github.com/Hoshock/orbit/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --target=bun --outdir=dist",
    "lint": "bunx biome check --write --unsafe src/",
    "test": "bun test",
    "check": "bunx biome check src/ && bun build src/index.tsx --target=bun --outdir=dist",
    "register": "bash scripts/register.sh"
  },
  "dependencies": {
    "@opentui/core": "^0.1.80",
    "@opentui/react": "^0.1.80",
    "react": "^19.2.4"
  }
}
