{
  "name": "crev",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --target=bun --outdir=dist",
    "lint": "bunx biome check --write --unsafe src/",
    "check": "bunx biome check src/ && bun build src/index.tsx --target=bun --outdir=dist",
    "register": "bash scripts/register.sh"
  },
  "dependencies": {
    "@opentui/core": "^0.1.80",
    "@opentui/react": "^0.1.80",
    "react": "^19.2.4"
  }
}
